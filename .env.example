# Copy to .env.local for local dev. For production, create .env.production and use:
#   ./scripts/deploy.sh --with-env   (copies .env.production to server as .env)
#   or when running setup-server: ENV_FILE=/path/to/.env.production
#
# Site URL (for Stripe redirects and webhooks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — use test keys for dev, live keys for production
# Get keys: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal (optional)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Database (локально: контейнер Docker, напр. docker exec -it pensive_turing psql -U postgres -d postgres)
# Подключение с хоста: порт контейнера должен быть проброшен на localhost:5432
# База wcd будет создана при npm run db:setup, миграции накатятся в неё
DATABASE_URL=postgresql://postgres:ПАРОЛЬ@localhost:5432/wcd

# Admin — при старте (dev/start) админ создаётся/обновляется из этих переменных
ADMIN_EMAIL=admin@worldclapday.com
ADMIN_PASSWORD=

# Clapper auto-increment (тик каждые N мс, за тик добавляется случайное число от MIN до MAX)
# Cron должен вызывать /api/cron/clapper-tick с тем же интервалом (по умолчанию 5 сек)
NEXT_PUBLIC_CLAPPER_TICK_INTERVAL_MS=5000
NEXT_PUBLIC_CLAPPER_ADD_MIN=1
NEXT_PUBLIC_CLAPPER_ADD_MAX=5

# Google Analytics 4 — use a separate GA4 property for beta vs production
# Get ID at: https://analytics.google.com -> Admin -> Data Streams -> your stream -> Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
