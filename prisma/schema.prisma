generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Supporter {
  id            String   @id @default(cuid())
  name          String
  email         String?
  country       String?
  countryCode   String?
  tier          String   @default("single-clap")
  amount        Float?
  paymentMethod String?
  paymentId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model MailingListSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  isActive       Boolean   @default(true)

  @@index([email])
  @@index([isActive])
}

model SiteStats {
  id                String   @id @default("main")
  clapperCount      Int      @default(64241)
  updatedAt         DateTime @updatedAt
  clapperCountFixed Int      @default(64241)
}

model ClapperCountryCount {
  countryCode String   @id
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserLocation {
  id          String   @id @default(cuid())
  city        String
  country     String
  countryCode String
  createdAt   DateTime @default(now())

  @@index([countryCode])
}
